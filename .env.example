# ── Server Transport ──────────────────────────────────────────────────────────
# Set to "stdio" for Claude Desktop / CLI usage, "sse" for HTTP SSE mode (default)
MCP_TRANSPORT=sse

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Gmail SMTP (for send_email tool) ─────────────────────────────────────────
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SENDER_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# ── NewsAPI (for fetch_news tool — https://newsapi.org) ──────────────────────
NEWS_API_KEY=your_news_api_key_here

# ── Strava (for get_recent_activities / get_weekly_summary tools) ─────────────
# Create an app at https://www.strava.com/settings/api, then generate a
# refresh token with activity:read scope.
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token
